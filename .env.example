# Privacy Panda Environment Variables
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Required for database operations, authentication, and real-time features
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
VITE_DB_SCHEMA_PREFIX=pandagarde_

# =============================================================================
# SENTRY ERROR MONITORING
# =============================================================================
# Required for production error tracking and performance monitoring
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_SENTRY_ORG=your-sentry-org
VITE_SENTRY_PROJECT=your-sentry-project
VITE_SENTRY_AUTH_TOKEN=your-sentry-auth-token
VITE_SENTRY_DEBUG=false

# =============================================================================
# ANALYTICS CONFIGURATION
# =============================================================================
# Required for user analytics and behavior tracking
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX
VITE_ANALYTICS_DEBUG=false

# =============================================================================
# SERVICE WORKER CONFIGURATION
# =============================================================================
# Enable/disable service worker for offline functionality
VITE_SW_ENABLED=true

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
# Set to 'development' for local development
NODE_ENV=development

# =============================================================================
# PRODUCTION CONFIGURATION
# =============================================================================
# Set to 'production' for production builds
# NODE_ENV=production

# =============================================================================
# NOTES
# =============================================================================
# 1. Never commit .env.local to version control
# 2. All VITE_ prefixed variables are exposed to the client-side code
# 3. Use strong, unique keys for production environments
# 4. Test all integrations in development before deploying to production
# 5. Monitor Sentry and Analytics dashboards after deployment