# PandaGarde Environment Configuration
# Copy this file to .env.local and update with your actual Supabase credentials

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Database Schema Prefix (prevents conflicts with other projects)
VITE_DB_SCHEMA_PREFIX=pandagarde_

# Optional: Service Role Key for admin operations
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here